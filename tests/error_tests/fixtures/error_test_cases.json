{
  "connection_errors": {
    "refused": {
      "address": "127.0.0.1:9999",
      "expected_code": 1001,
      "expected_retryable": true,
      "description": "Connection refused - no server listening"
    },
    "timeout": {
      "address": "10.255.255.1:9999",
      "expected_code": 1002,
      "expected_retryable": true,
      "description": "Connection timeout - non-routable IP"
    }
  },
  "validation_errors": {
    "invalid_latitude_too_high": {
      "latitude": 200.0,
      "longitude": 0.0,
      "expected_code": 3001,
      "expected_retryable": false,
      "description": "Latitude exceeds +90 degrees"
    },
    "invalid_latitude_too_low": {
      "latitude": -200.0,
      "longitude": 0.0,
      "expected_code": 3001,
      "expected_retryable": false,
      "description": "Latitude below -90 degrees"
    },
    "invalid_longitude_too_high": {
      "latitude": 0.0,
      "longitude": 400.0,
      "expected_code": 3001,
      "expected_retryable": false,
      "description": "Longitude exceeds +180 degrees"
    },
    "invalid_longitude_too_low": {
      "latitude": 0.0,
      "longitude": -400.0,
      "expected_code": 3001,
      "expected_retryable": false,
      "description": "Longitude below -180 degrees"
    },
    "invalid_entity_id_zero": {
      "entity_id": 0,
      "expected_code": 3004,
      "expected_retryable": false,
      "description": "Entity ID cannot be zero"
    }
  },
  "server_errors": {
    "http_500": {
      "expected_code": 2001,
      "expected_retryable": true,
      "description": "Internal server error - cluster unavailable"
    },
    "http_429": {
      "expected_code": 2002,
      "expected_retryable": true,
      "description": "Rate limited (view change) - should retry with backoff"
    },
    "http_503": {
      "expected_code": 2003,
      "expected_retryable": true,
      "description": "Service unavailable (not primary) - should retry"
    }
  },
  "batch_errors": {
    "batch_too_large": {
      "batch_size": 10001,
      "max_batch_size": 10000,
      "expected_code": 3003,
      "expected_retryable": false,
      "description": "Batch exceeds 10,000 event limit"
    }
  },
  "empty_results": {
    "empty_radius_query": {
      "latitude": 0.0,
      "longitude": 0.0,
      "radius_m": 1.0,
      "expected_count": 0,
