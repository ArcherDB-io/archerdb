# Common webhook destinations:
#
# Discord:
#   url: 'https://discord.com/api/webhooks/<WEBHOOK_ID>/<TOKEN>'
#   Note: Requires custom formatting, consider using a proxy service
#
# Microsoft Teams:
#   url: 'https://outlook.office.com/webhook/<GUID>/IncomingWebhook/<PATH>'
#   Note: Teams expects a specific format, use alertmanager-webhook-teams-adapter
#
# Mattermost:
#   url: 'https://mattermost.example.com/hooks/<HOOK_ID>'
#   Note: Mattermost can accept Alertmanager payloads natively
#
# Custom Lambda/Cloud Function:
#   url: 'https://api.example.com/alerts'
#   Note: Implement your own logic to transform and route alerts
