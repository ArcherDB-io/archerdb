# Generic Webhook Receiver Configuration Template for Alertmanager
#
# Copy this receiver configuration into your alertmanager.yml file.
# Replace <YOUR_WEBHOOK_URL> with your endpoint URL.
#
# This template is useful for:
# - Custom notification systems
# - Chat integrations (Discord, Mattermost, etc.)
# - Incident management systems
# - Automation triggers (Lambda, Cloud Functions, etc.)
# - Custom dashboards or alerting systems
#
# The webhook receives a JSON payload with the following structure:
# {
#   "version": "4",
#   "groupKey": "<group key>",
#   "status": "firing|resolved",
#   "receiver": "<receiver name>",
#   "groupLabels": {...},
#   "commonLabels": {...},
#   "commonAnnotations": {...},
#   "externalURL": "<alertmanager URL>",
#   "alerts": [
#     {
#       "status": "firing|resolved",
#       "labels": {...},
#       "annotations": {...},
#       "startsAt": "<timestamp>",
#       "endsAt": "<timestamp>",
#       "generatorURL": "<prometheus URL>"
#     }
#   ]
# }

receivers:
  - name: 'archerdb-webhook'
    webhook_configs:
      - url: '<YOUR_WEBHOOK_URL>'
        send_resolved: true
        max_alerts: 10
        # Uncomment and configure if your webhook requires authentication
        # http_config:
        #   basic_auth:
        #     username: '<USERNAME>'
        #     password: '<PASSWORD>'
        #   # Or use bearer token:
        #   # authorization:
        #   #   type: Bearer
        #   #   credentials: '<TOKEN>'
        #   # Or use OAuth2:
        #   # oauth2:
        #   #   client_id: '<CLIENT_ID>'
        #   #   client_secret: '<CLIENT_SECRET>'
        #   #   token_url: '<TOKEN_URL>'
        #   # Custom headers:
        #   # headers:
        #   #   X-Custom-Header: 'value'

  - name: 'archerdb-webhook-critical'
    webhook_configs:
      - url: '<YOUR_CRITICAL_WEBHOOK_URL>'
        send_resolved: true
        max_alerts: 0  # No limit for critical alerts
        # http_config:
        #   tls_config:
        #     insecure_skip_verify: false  # Always verify TLS in production

