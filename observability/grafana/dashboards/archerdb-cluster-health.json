{
  "uid": "archerdb-cluster-health",
  "title": "ArcherDB Cluster Health",
  "description": "Purpose: Consolidated operational view of connection pool health, load shedding, read replica routing, and VSR consensus state.\n\nWhen to use: Day-to-day cluster operations, incident response, and post-change validation.\n\nPrerequisites: Phase 15 metrics enabled (archerdb_pool, archerdb_shed, archerdb_routing, archerdb_vsr_*).\n\nRelated dashboards: Cluster Detail (/d/archerdb-cluster/archerdb-cluster), Overview (/d/archerdb-overview/archerdb-overview).\n\nDashboard version v1 - created 2026-01-25.",
  "tags": ["archerdb", "cluster", "health", "overview"],
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "schemaVersion": 39,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "fiscalYearStartMonth": 0,
  "liveNow": false,
  "weekStart": "",
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "label": "Data Source",
        "description": "Select the Prometheus data source",
        "query": "prometheus",
        "current": {},
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "options": [],
        "refresh": 1,
        "regex": ""
      },
      {
        "name": "instance",
        "type": "query",
        "label": "Node",
        "description": "Filter by ArcherDB node instance",
        "datasource": {"type": "prometheus", "uid": "${datasource}"},
        "query": "label_values(archerdb_info, instance)",
        "refresh": 1,
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "current": {},
        "hide": 0,
        "options": [],
        "regex": "",
        "sort": 1
      }
    ]
  },
  "annotations": {
    "list": [
      {
        "name": "View Changes",
        "datasource": {"type": "prometheus", "uid": "${datasource}"},
        "enable": true,
        "expr": "changes(archerdb_vsr_view[5m]) > 0",
        "iconColor": "orange",
        "tagKeys": "instance",
        "textFormat": "VSR view change on {{ instance }}",
        "titleFormat": "View Change",
        "useValueForTime": false
      }
    ]
  },
  "links": [
    {
      "title": "Cluster Detail",
      "type": "link",
      "url": "/d/archerdb-cluster/archerdb-cluster?orgId=1&${__url_time_range}&${__all_variables}",
      "icon": "external link",
      "tooltip": "Detailed cluster metrics",
      "keepTime": true,
      "includeVars": true,
      "targetBlank": false,
      "asDropdown": false
    },
    {
      "title": "Overview",
      "type": "link",
      "url": "/d/archerdb-overview/archerdb-overview?orgId=1&${__url_time_range}&${__all_variables}",
      "icon": "external link",
      "tooltip": "Return to cluster overview dashboard",
      "keepTime": true,
      "includeVars": true,
      "targetBlank": false,
      "asDropdown": false
    }
  ],
  "panels": [
    {
      "type": "row",
      "title": "Overview Stats",
      "gridPos": {"x": 0, "y": 0, "w": 24, "h": 1},
      "id": 100,
      "collapsed": false,
      "panels": []
    },
    {
      "type": "stat",
      "title": "Total Connections",
      "description": "Total active + idle connections in the server-side pool. Sustained growth indicates increased client load or potential leaks.",
      "gridPos": {"x": 0, "y": 1, "w": 6, "h": 6},
      "id": 1,
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {
          "expr": "sum(archerdb_pool_connections_active{instance=~\"$instance\"}) + sum(archerdb_pool_connections_idle{instance=~\"$instance\"})",
          "legendFormat": "Connections",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null}
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "textMode": "value_and_name",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      }
    },
    {
      "type": "stat",
      "title": "Load Shedding Active",
      "description": "Boolean indicator for active load shedding (shed score >= threshold). 1 indicates new requests are being rejected.",
      "gridPos": {"x": 6, "y": 1, "w": 6, "h": 6},
      "id": 2,
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {
          "expr": "max(archerdb_shed_score{instance=~\"$instance\"}) >= max(archerdb_shed_threshold{instance=~\"$instance\"})",
          "legendFormat": "Shedding",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "red", "value": 1}
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "value_and_name",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      }
    },
    {
      "type": "stat",
      "title": "Healthy Replicas",
      "description": "Count of replicas reporting healthy routing state (health=1). Zero indicates all reads will fail over to leader.",
      "gridPos": {"x": 12, "y": 1, "w": 6, "h": 6},
      "id": 3,
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {
          "expr": "sum(archerdb_routing_replica_health)",
          "legendFormat": "Healthy",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "yellow", "value": 1},
              {"color": "green", "value": 2}
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "value_and_name",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      }
    },
    {
      "type": "stat",
      "title": "Consensus Status",
      "description": "Replica status: 0=normal, 1=view_change, 2=recovering. Non-zero means consensus is in transition.",
      "gridPos": {"x": 18, "y": 1, "w": 6, "h": 6},
      "id": 4,
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {
          "expr": "max(archerdb_vsr_status{instance=~\"$instance\"})",
          "legendFormat": "Status",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 1},
              {"color": "red", "value": 2}
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "value_and_name",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      }
    },
    {
      "type": "row",
      "title": "Overview Info",
      "gridPos": {"x": 0, "y": 7, "w": 24, "h": 1},
      "id": 200,
      "collapsed": true,
      "panels": [
        {
          "type": "text",
          "title": "Overview Stats Info",
          "description": "Summary guidance for cluster overview stats.",
          "gridPos": {"x": 0, "y": 0, "w": 24, "h": 4},
          "id": 201,
          "options": {
            "mode": "markdown",
            "content": "**Metrics:** pool connection totals, load shedding active flag, healthy replica count, and VSR status.\n\n**Healthy:** shedding inactive, >=1 healthy replica, status=0 (normal).\n\n**Troubleshooting:** confirm pool waiters, check replica health endpoints, inspect VSR logs for view changes.\n\n**Runbook:** https://docs.archerdb.io/runbooks/cluster-health"
          }
        }
      ]
    },
    {
      "type": "row",
      "title": "Connection Pool",
      "gridPos": {"x": 0, "y": 8, "w": 24, "h": 1},
      "id": 101,
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "Active vs Idle Connections",
      "description": "Active and idle connections per node. Idle should remain above zero during steady-state; spikes in active connections may indicate bursts or leaks.",
      "gridPos": {"x": 0, "y": 9, "w": 12, "h": 8},
      "id": 5,
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {
          "expr": "archerdb_pool_connections_active{instance=~\"$instance\"}",
          "legendFormat": "Active {{instance}}",
          "refId": "A"
        },
        {
          "expr": "archerdb_pool_connections_idle{instance=~\"$instance\"}",
          "legendFormat": "Idle {{instance}}",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "fillOpacity": 10,
            "showPoints": "never",
            "stacking": {"mode": "none", "group": "A"},
            "axisPlacement": "auto",
            "axisColorMode": "text",
            "scaleDistribution": {"type": "linear"}
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {"mode": "multi", "sort": "desc"},
        "legend": {"displayMode": "table", "placement": "bottom", "showLegend": true, "calcs": ["mean", "max"]}
      }
    },
    {
      "type": "gauge",
      "title": "Pool Utilization %",
      "description": "Percentage of active connections relative to active+idle pool size. Sustained >90% indicates pool saturation.",
      "gridPos": {"x": 12, "y": 9, "w": 4, "h": 8},
      "id": 6,
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {
          "expr": "(sum(archerdb_pool_connections_active{instance=~\"$instance\"}) / (sum(archerdb_pool_connections_active{instance=~\"$instance\"}) + sum(archerdb_pool_connections_idle{instance=~\"$instance\"}))) * 100",
          "legendFormat": "Utilization",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 70},
              {"color": "red", "value": 90}
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "showThresholdLabels": true,
        "showThresholdMarkers": true,
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      }
    },
    {
      "type": "stat",
      "title": "Acquire Ops/sec",
      "description": "Rate of connection acquire operations across the cluster. Correlates with client load.",
      "gridPos": {"x": 16, "y": 9, "w": 4, "h": 8},
      "id": 7,
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {
          "expr": "sum(rate(archerdb_pool_acquire_total{instance=~\"$instance\"}[5m]))",
          "legendFormat": "Acquire",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null}
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "textMode": "value_and_name",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      }
    },
    {
      "type": "stat",
      "title": "Acquire Timeout Rate",
      "description": "Rate of acquire timeouts. Any sustained non-zero rate indicates pool pressure or a sizing issue.",
      "gridPos": {"x": 20, "y": 9, "w": 4, "h": 8},
      "id": 8,
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {
          "expr": "sum(rate(archerdb_pool_acquire_timeout_total{instance=~\"$instance\"}[5m]))",
          "legendFormat": "Timeout",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "red", "value": 0.1}
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "value_and_name",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Health Check Failures",
      "description": "Rate of failed pool health checks. Non-zero values indicate unhealthy connections being closed.",
      "gridPos": {"x": 0, "y": 17, "w": 24, "h": 6},
      "id": 9,
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {
          "expr": "sum(rate(archerdb_pool_health_check_failed_total{instance=~\"$instance\"}[5m]))",
          "legendFormat": "Failures",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "fillOpacity": 10,
            "showPoints": "never",
            "stacking": {"mode": "none", "group": "A"},
            "axisPlacement": "auto",
            "axisColorMode": "text",
            "scaleDistribution": {"type": "linear"}
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {"mode": "multi", "sort": "desc"},
        "legend": {"displayMode": "table", "placement": "bottom", "showLegend": true, "calcs": ["mean", "max"]}
      }
    },
    {
      "type": "row",
      "title": "Connection Pool Info",
      "gridPos": {"x": 0, "y": 23, "w": 24, "h": 1},
      "id": 202,
      "collapsed": true,
      "panels": [
        {
          "type": "text",
          "title": "Connection Pool Info",
          "description": "Operational guidance for connection pool metrics.",
          "gridPos": {"x": 0, "y": 0, "w": 24, "h": 4},
          "id": 203,
          "options": {
            "mode": "markdown",
            "content": "**Metrics:** active/idle pool counts, utilization, acquire rate, timeout rate, health check failures.\n\n**Healthy:** idle > 0, timeouts near zero, health check failures near zero.\n\n**Troubleshooting:** inspect pool size limits, confirm waiters, and investigate backend connection health.\n\n**Runbook:** https://docs.archerdb.io/runbooks/connection-pool"
          }
        }
      ]
    },
    {
      "type": "row",
      "title": "Load Shedding",
      "gridPos": {"x": 0, "y": 24, "w": 24, "h": 1},
      "id": 102,
      "collapsed": false,
      "panels": []
    },
    {
      "type": "gauge",
      "title": "Composite Score",
      "description": "Current overload score (0-100). Values above the threshold indicate active shedding.",
      "gridPos": {"x": 0, "y": 25, "w": 6, "h": 8},
      "id": 10,
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {
          "expr": "max(archerdb_shed_score{instance=~\"$instance\"})",
          "legendFormat": "Score",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 70},
              {"color": "red", "value": 90}
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "showThresholdLabels": true,
        "showThresholdMarkers": true,
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Shed Requests Rate",
      "description": "Rate of requests rejected due to load shedding. Use alongside score to determine sustained overload.",
      "gridPos": {"x": 6, "y": 25, "w": 6, "h": 8},
      "id": 11,
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {
          "expr": "sum(rate(archerdb_shed_requests_total{instance=~\"$instance\"}[5m]))",
          "legendFormat": "Shed/sec",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "fillOpacity": 10,
            "showPoints": "never",
            "stacking": {"mode": "none", "group": "A"},
            "axisPlacement": "auto",
            "axisColorMode": "text",
            "scaleDistribution": {"type": "linear"}
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {"mode": "multi", "sort": "desc"},
        "legend": {"displayMode": "table", "placement": "bottom", "showLegend": true, "calcs": ["mean", "max"]}
      }
    },
    {
      "type": "timeseries",
      "title": "Score Components",
      "description": "Component signals feeding the composite shed score: queue depth, P99 latency, and memory pressure.",
      "gridPos": {"x": 12, "y": 25, "w": 12, "h": 8},
      "id": 12,
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {
          "expr": "max(archerdb_shed_queue_depth{instance=~\"$instance\"})",
          "legendFormat": "Queue Depth",
          "refId": "A"
        },
        {
          "expr": "max(archerdb_shed_latency_p99_ms{instance=~\"$instance\"})",
          "legendFormat": "Latency P99 (ms)",
          "refId": "B"
        },
        {
          "expr": "max(archerdb_shed_memory_pressure_pct{instance=~\"$instance\"})",
          "legendFormat": "Memory Pressure %",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "fillOpacity": 10,
            "showPoints": "never",
            "stacking": {"mode": "none", "group": "A"},
            "axisPlacement": "auto",
            "axisColorMode": "text",
            "scaleDistribution": {"type": "linear"}
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {"mode": "multi", "sort": "desc"},
        "legend": {"displayMode": "table", "placement": "bottom", "showLegend": true, "calcs": ["mean", "max"]}
      }
    },
    {
      "type": "heatmap",
      "title": "Retry-After Distribution",
      "description": "Heatmap of Retry-After values returned to clients. Higher buckets indicate more severe overload.",
      "gridPos": {"x": 0, "y": 33, "w": 24, "h": 8},
      "id": 13,
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {
          "expr": "sum(rate(archerdb_shed_retry_after_ms_bucket{instance=~\"$instance\"}[5m])) by (le)",
          "legendFormat": "{{le}} ms",
          "refId": "A",
          "format": "heatmap"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "scaleDistribution": {"type": "linear"}
          }
        },
        "overrides": []
      },
      "options": {
        "color": {"mode": "scheme", "scheme": "Spectral"},
        "legend": {"show": true},
        "tooltip": {"show": true}
      }
    },
    {
      "type": "row",
      "title": "Load Shedding Info",
      "gridPos": {"x": 0, "y": 41, "w": 24, "h": 1},
      "id": 204,
      "collapsed": true,
      "panels": [
        {
          "type": "text",
          "title": "Load Shedding Info",
          "description": "Operational guidance for load shedding metrics.",
          "gridPos": {"x": 0, "y": 0, "w": 24, "h": 4},
          "id": 205,
          "options": {
            "mode": "markdown",
            "content": "**Metrics:** composite score, shed request rate, signal components, Retry-After distribution.\n\n**Healthy:** score below threshold, shed rate near zero, Retry-After buckets quiet.\n\n**Troubleshooting:** inspect queue depth, latency P99, and memory pressure signals; reduce load if sustained.\n\n**Runbook:** https://docs.archerdb.io/runbooks/load-shedding"
          }
        }
      ]
    },
    {
      "type": "row",
      "title": "Read Replica Routing",
      "gridPos": {"x": 0, "y": 42, "w": 24, "h": 1},
      "id": 103,
      "collapsed": false,
      "panels": []
    },
    {
      "type": "piechart",
      "title": "Replica vs Leader Reads",
      "description": "Distribution of read traffic between replicas and leader failover. High leader share indicates unhealthy replicas.",
      "gridPos": {"x": 0, "y": 43, "w": 6, "h": 8},
      "id": 14,
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {
          "expr": "sum(rate(archerdb_routing_to_replica_total{instance=~\"$instance\"}[5m]))",
          "legendFormat": "Replica",
          "refId": "A"
        },
        {
          "expr": "sum(rate(archerdb_routing_failover_total{instance=~\"$instance\"}[5m]))",
          "legendFormat": "Leader Failover",
          "refId": "B"
        }
      ],
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "displayLabels": ["name", "percent"],
        "legend": {"displayMode": "list", "placement": "bottom", "showLegend": true}
      }
    },
    {
      "type": "timeseries",
      "title": "Routing Decisions/sec",
      "description": "Rate of routing decisions by type (reads, writes, and failovers). Spikes in failovers indicate replica instability.",
      "gridPos": {"x": 6, "y": 43, "w": 6, "h": 8},
      "id": 15,
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {
          "expr": "sum(rate(archerdb_routing_reads_total{instance=~\"$instance\"}[5m]))",
          "legendFormat": "Reads",
          "refId": "A"
        },
        {
          "expr": "sum(rate(archerdb_routing_writes_total{instance=~\"$instance\"}[5m]))",
          "legendFormat": "Writes",
          "refId": "B"
        },
        {
          "expr": "sum(rate(archerdb_routing_failover_total{instance=~\"$instance\"}[5m]))",
          "legendFormat": "Failovers",
          "refId": "C"
        }
      ],
      "fieldConfig": {
