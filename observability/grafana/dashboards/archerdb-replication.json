{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      },
      {
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "enable": true,
        "expr": "changes(archerdb_vsr_view{instance=~\"$instance\"}[5m]) > 0",
        "iconColor": "orange",
        "name": "View Changes",
        "tagKeys": "instance",
        "textFormat": "VSR view change on {{ instance }}",
        "titleFormat": "View Change"
      },
      {
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "enable": true,
        "expr": "changes(archerdb_vsr_is_primary{instance=~\"$instance\"}[5m]) > 0",
        "iconColor": "red",
        "name": "Primary Changes",
        "tagKeys": "instance",
        "textFormat": "Primary election on {{ instance }}",
        "titleFormat": "Failover"
      }
    ]
  },
  "description": "Detailed VSR (Viewstamped Replication) consensus monitoring for ArcherDB clusters. Shows replication state, lag metrics, view changes, and primary status.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
