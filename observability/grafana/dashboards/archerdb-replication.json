    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "description": "Shows which node is currently the primary (leader). The primary accepts writes and coordinates replication to replicas.\n\nDuring failover, this panel will briefly show no primary while a new leader is being elected. If no primary is shown for more than a few seconds, check cluster connectivity.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "unit": "none"
        },
        "overrides": []
