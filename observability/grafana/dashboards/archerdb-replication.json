          "editorMode": "code",
          "expr": "archerdb_vsr_replication_lag_ops{instance=~\"$instance\"}",
          "legendFormat": "{{ instance }}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Lag by Operations",
      "type": "timeseries"
