{
  "operation": "query_uuid_batch",
  "version": "1.0.0",
  "description": "Test cases for batch query by UUID/entity_id operation (opcode 156)",
  "cases": [
    {
      "name": "batch_all_exist",
      "description": "Query multiple entities that all exist",
      "tags": ["smoke"],
      "input": {
        "setup": {
          "insert_first": [
            {"entity_id": 50001, "latitude": 40.7128, "longitude": -74.0060},
            {"entity_id": 50002, "latitude": 37.7749, "longitude": -122.4194},
            {"entity_id": 50003, "latitude": 51.5074, "longitude": -0.1278}
          ]
        },
        "entity_ids": [50001, 50002, 50003]
      },
      "expected_output": {
        "found_count": 3,
        "events": [
          {"entity_id": 50001, "latitude": 40.7128, "longitude": -74.0060},
          {"entity_id": 50002, "latitude": 37.7749, "longitude": -122.4194},
          {"entity_id": 50003, "latitude": 51.5074, "longitude": -0.1278}
        ]
      },
      "expected_error": null
    },
    {
      "name": "batch_partial",
      "description": "Query where some entities exist and some don't",
      "tags": ["pr"],
      "input": {
        "setup": {
          "insert_first": [
            {"entity_id": 50101, "latitude": 40.7128, "longitude": -74.0060},
            {"entity_id": 50103, "latitude": 51.5074, "longitude": -0.1278}
          ]
        },
        "entity_ids": [50101, 50102, 50103, 50104]
      },
      "expected_output": {
        "found_count": 2,
        "events": [
          {"entity_id": 50101, "latitude": 40.7128, "longitude": -74.0060},
          null,
          {"entity_id": 50103, "latitude": 51.5074, "longitude": -0.1278},
          null
        ]
      },
      "expected_error": null
    },
    {
      "name": "batch_none_exist",
      "description": "Query where no entities exist",
      "tags": ["pr"],
      "input": {
        "entity_ids": [77777771, 77777772, 77777773]
      },
      "expected_output": {
        "found_count": 0,
        "events": [null, null, null]
      },
      "expected_error": null
    },
    {
      "name": "batch_empty",
      "description": "Query with empty entity list",
      "tags": ["nightly"],
      "input": {
        "entity_ids": []
      },
      "expected_output": {
        "found_count": 0,
        "events": []
      },
      "expected_error": null
    },
    {
      "name": "batch_large",
      "description": "Query large batch of 100 entities",
      "tags": ["nightly"],
      "input": {
        "setup": {
          "insert_first_range": {
            "start_entity_id": 50200,
            "count": 100,
            "base_latitude": 40.7128,
            "base_longitude": -74.0060
          }
        },
        "entity_ids_range": {
          "start": 50200,
          "count": 100
        }
      },
      "expected_output": {
        "found_count": 100
      },
      "expected_error": null
    }
  ]
}
