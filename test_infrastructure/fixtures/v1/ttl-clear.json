{
  "operation": "ttl_clear",
  "version": "1.0.0",
  "description": "Test cases for TTL clear operation (opcode 160)",
  "cases": [
    {
      "name": "clear_ttl_valid",
      "description": "Clear TTL on existing entity (make permanent)",
      "tags": [
        "smoke"
      ],
      "input": {
        "setup": {
          "insert_first": {
            "entity_id": 92001,
            "latitude": 40.7128,
            "longitude": -74.006,
            "ttl_seconds": 3600
          }
        },
        "entity_id": 92001
      },
      "expected_output": {
        "result_code": 0,
        "status": "OK",
        "ttl_seconds": 0,
        "_note": "Entity now permanent (no TTL)"
      },
      "expected_error": null
    },
    {
      "name": "clear_ttl_entity_not_found",
      "description": "Clear TTL on non-existent entity",
      "tags": [
        "pr"
      ],
      "input": {
        "entity_id": 99999999
      },
      "expected_output": {
        "result_code": 1,
        "status": "ENTITY_NOT_FOUND"
      },
      "expected_error": null
    },
    {
      "name": "clear_ttl_already_permanent",
      "description": "Clear TTL on entity that already has no TTL",
      "tags": [
        "pr"
      ],
      "input": {
        "setup": {
          "insert_first": {
            "entity_id": 92002,
            "latitude": 40.7128,
            "longitude": -74.006
          }
        },
        "entity_id": 92002
      },
      "expected_output": {
        "result_code": 0,
        "status": "OK",
        "_note": "Idempotent - clearing already-clear TTL succeeds"
      },
      "expected_error": null
    },
    {
      "name": "clear_ttl_verify_permanent",
      "description": "Verify entity persists after TTL cleared",
      "tags": [
        "nightly"
      ],
      "input": {
        "setup": {
          "insert_first": {
            "entity_id": 92003,
            "latitude": 40.7128,
            "longitude": -74.006,
            "ttl_seconds": 3
          },
          "then_clear_ttl": 92003,
          "then_wait_seconds": 5
        },
        "query_entity_id": 92003
      },
      "expected_output": {
        "entity_still_exists": true,
        "_note": "Entity should persist after original TTL would have expired"
      },
      "expected_error": null
    }
  ]
}
