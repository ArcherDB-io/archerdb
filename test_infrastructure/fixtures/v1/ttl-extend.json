{
  "operation": "ttl_extend",
  "version": "1.0.0",
  "description": "Test cases for TTL extend operation (opcode 159)",
  "cases": [
    {
      "name": "extend_ttl_valid",
      "description": "Extend TTL on existing entity with TTL",
      "tags": [
        "smoke"
      ],
      "input": {
        "setup": {
          "insert_first": {
            "entity_id": 91001,
            "latitude": 40.7128,
            "longitude": -74.006,
            "ttl_seconds": 1800
          }
        },
        "entity_id": 91001,
        "extend_by_seconds": 1800
      },
      "expected_output": {
        "result_code": 0,
        "status": "OK",
        "new_ttl_min_seconds": 3500
      },
      "expected_error": null
    },
    {
      "name": "extend_ttl_entity_not_found",
      "description": "Extend TTL on non-existent entity",
      "tags": [
        "pr"
      ],
      "input": {
        "entity_id": 99999999,
        "extend_by_seconds": 1800
      },
      "expected_output": {
        "result_code": 1,
        "status": "ENTITY_NOT_FOUND"
      },
      "expected_error": null
    },
    {
      "name": "extend_ttl_no_existing_ttl",
      "description": "Extend TTL on entity without existing TTL",
      "tags": [
        "pr"
      ],
      "input": {
        "setup": {
          "insert_first": {
            "entity_id": 91002,
            "latitude": 40.7128,
            "longitude": -74.006
          }
        },
        "entity_id": 91002,
        "extend_by_seconds": 3600
      },
      "expected_output": {
        "result_code": 0,
        "status": "OK",
        "_note": "May set new TTL or return error depending on implementation"
      },
      "expected_error": null
    },
    {
      "name": "extend_ttl_near_max",
      "description": "Extend TTL near maximum value",
      "tags": [
        "nightly"
      ],
      "input": {
        "setup": {
          "insert_first": {
            "entity_id": 91003,
            "latitude": 40.7128,
            "longitude": -74.006,
            "ttl_seconds": 31000000
          }
        },
        "entity_id": 91003,
        "extend_by_seconds": 1000000
      },
      "expected_output": {
        "result_code": 0,
        "status": "OK",
        "_note": "Should cap at maximum TTL if exceeded"
      },
      "expected_error": null
    }
  ]
}
