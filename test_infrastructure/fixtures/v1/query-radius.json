{
  "operation": "query_radius",
  "version": "1.0.0",
  "description": "Test cases for radius query operation (opcode 150)",
  "cases": [
    {
      "name": "basic_radius_1km",
      "description": "Basic 1km radius query",
      "tags": ["smoke"],
      "input": {
        "setup": {
          "insert_first": [
            {"entity_id": 60001, "latitude": 40.7128, "longitude": -74.0060},
            {"entity_id": 60002, "latitude": 40.7130, "longitude": -74.0062},
            {"entity_id": 60003, "latitude": 40.7500, "longitude": -74.0500}
          ]
        },
        "center_latitude": 40.7128,
        "center_longitude": -74.0060,
        "radius_m": 1000
      },
      "expected_output": {
        "count_in_range": 2,
        "events_contain": [60001, 60002]
      },
      "expected_error": null
    },
    {
      "name": "radius_with_limit",
      "description": "Radius query with limit=10",
      "tags": ["pr"],
      "input": {
        "setup": {
          "insert_first_range": {
            "start_entity_id": 60100,
            "count": 50,
            "base_latitude": 40.7128,
            "base_longitude": -74.0060,
            "spread_m": 500
          }
        },
        "center_latitude": 40.7128,
        "center_longitude": -74.0060,
        "radius_m": 1000,
        "limit": 10
      },
      "expected_output": {
        "count": 10,
        "limit_applied": true
      },
      "expected_error": null
    },
    {
      "name": "radius_empty_result",
      "description": "Radius query that matches no events",
      "tags": ["pr"],
      "input": {
        "center_latitude": 0.0,
        "center_longitude": 0.0,
        "radius_m": 100
      },
      "expected_output": {
        "count": 0,
        "events": []
      },
      "expected_error": null
    },
    {
      "name": "large_radius_100km",
      "description": "Wide area query with 100km radius",
      "tags": ["nightly"],
      "input": {
        "setup": {
          "insert_first": [
            {"entity_id": 60201, "latitude": 40.7128, "longitude": -74.0060},
            {"entity_id": 60202, "latitude": 40.8000, "longitude": -73.9500},
            {"entity_id": 60203, "latitude": 41.0000, "longitude": -73.5000}
          ]
        },
        "center_latitude": 40.7128,
        "center_longitude": -74.0060,
        "radius_m": 100000
      },
      "expected_output": {
        "count_in_range": 3,
        "events_contain": [60201, 60202, 60203]
      },
      "expected_error": null
    },
    {
      "name": "small_radius_1m",
      "description": "Very precise 1m radius query",
      "tags": ["nightly"],
      "input": {
        "setup": {
          "insert_first": [
            {"entity_id": 60301, "latitude": 40.7128000, "longitude": -74.0060000},
            {"entity_id": 60302, "latitude": 40.7128001, "longitude": -74.0060001}
          ]
        },
        "center_latitude": 40.7128000,
        "center_longitude": -74.0060000,
        "radius_m": 1
      },
      "expected_output": {
        "count_in_range_min": 1,
        "events_contain": [60301]
      },
      "expected_error": null
    },
    {
      "name": "radius_at_pole",
      "description": "Query near north pole",
      "tags": ["nightly"],
      "input": {
        "setup": {
          "insert_first": [
            {"entity_id": 60401, "latitude": 89.9, "longitude": 0.0},
            {"entity_id": 60402, "latitude": 89.95, "longitude": 90.0}
          ]
        },
        "center_latitude": 90.0,
        "center_longitude": 0.0,
        "radius_m": 50000
      },
      "expected_output": {
        "count_in_range": 2,
        "events_contain": [60401, 60402]
      },
      "expected_error": null
    },
    {
      "name": "radius_crossing_antimeridian",
      "description": "Query crossing the international dateline",
      "tags": ["nightly"],
      "input": {
        "setup": {
          "insert_first": [
            {"entity_id": 60501, "latitude": 0.0, "longitude": 179.9},
            {"entity_id": 60502, "latitude": 0.0, "longitude": -179.9}
          ]
        },
        "center_latitude": 0.0,
        "center_longitude": 180.0,
        "radius_m": 50000
      },
      "expected_output": {
        "count_in_range": 2,
        "events_contain": [60501, 60502]
      },
      "expected_error": null
    },
    {
      "name": "radius_with_group_filter",
      "description": "Radius query filtered by group_id",
      "tags": ["pr"],
      "input": {
        "setup": {
          "insert_first": [
            {"entity_id": 60601, "latitude": 40.7128, "longitude": -74.0060, "group_id": 100},
            {"entity_id": 60602, "latitude": 40.7129, "longitude": -74.0061, "group_id": 200},
            {"entity_id": 60603, "latitude": 40.7130, "longitude": -74.0062, "group_id": 100}
          ]
        },
        "center_latitude": 40.7128,
        "center_longitude": -74.0060,
        "radius_m": 1000,
        "group_id": 100
      },
      "expected_output": {
        "count": 2,
        "events_contain": [60601, 60603]
      },
      "expected_error": null
    },
    {
      "name": "hotspot_radius_query",
      "description": "Query 1km radius in area with 95% concentration for stress test",
      "tags": ["nightly"],
      "input": {
        "setup": {
          "insert_hotspot": {
            "center_latitude": 40.758896,
            "center_longitude": -73.985130,
            "count": 1000,
            "concentration_percentage": 95,
            "start_entity_id": 60700
          },
          "_metadata": {
            "hotspot_location": "Times Square, NYC",
            "purpose": "Stress test for query patterns with extreme point concentration"
          }
        },
        "center_latitude": 40.758896,
        "center_longitude": -73.985130,
        "radius_m": 1000,
        "limit": 500
      },
      "expected_output": {
        "count_min": 250,
        "all_within_radius": true,
        "_note": "Tests query performance with hotspot data distribution (lite config caps results)"
      },
      "expected_error": null
    },
    {
      "name": "radius_with_timestamp_filter",
      "description": "Radius query with timestamp range filter",
      "tags": ["nightly"],
      "input": {
        "setup": {
          "insert_with_timestamps": [
            {"entity_id": 60801, "latitude": 40.7128, "longitude": -74.0060, "timestamp": 1000},
            {"entity_id": 60802, "latitude": 40.7129, "longitude": -74.0061, "timestamp": 2000},
            {"entity_id": 60803, "latitude": 40.7130, "longitude": -74.0062, "timestamp": 3000}
          ]
        },
        "center_latitude": 40.7128,
        "center_longitude": -74.0060,
        "radius_m": 1000,
        "timestamp_min": 1500,
        "timestamp_max": 2500
      },
      "expected_output": {
        "count": 1,
        "events_contain": [60802]
      },
      "expected_error": null
    }
  ]
}
