{
  "name": "archerdb-node",
  "version": "0.1.0",
  "description": "ArcherDB Node.js client - High-performance geospatial database SDK",
  "main": "dist/index.js",
  "typings": "dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ArcherDB-io/archerdb.git",
    "directory": "src/clients/node"
  },
  "preferUnplugged": true,
  "files": [
    "LICENSE",
    "README.md",
    "dist",
    "src",
    "!src/zig-cache",
    "package.json",
    "package-lock.json",
    "tsconfig.json"
  ],
  "engines": {
    "node": ">=14.0.0"
  },
  "scripts": {
    "prepare": "tsc",
    "build": "tsc",
    "test": "tsc && node dist/geo_test.js",
    "test:types": "tsc --noEmit"
  },
  "author": "ArcherDB Team",
  "license": "Apache-2.0",
  "contributors": [
    "Donovan Changfoot <don@coil.com>",
    "Isaac Freund <isaac.freund@coil.com>",
    "Jason Bruwer <jason.bruwer@coil.com>",
    "Joran Dirk Greef <joran@tigerbeetle.com>"
  ],
  "keywords": [
    "archerdb",
    "geospatial",
    "database",
    "location",
    "s2",
    "coordinates",
    "fleet-tracking",
    "real-time"
  ],
  "devDependencies": {
    "@types/node": "^14.14.41",
    "node-api-headers": "^0.0.2",
    "typescript": "^4.0.2"
  }
}
